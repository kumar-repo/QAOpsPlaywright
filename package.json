    "@azure/identity": "^4.13.1",
    "@azure/playwright": "^1.1.4",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.4.0",
    "allure": "^0.0.0",
    "allure-playwright": "^3.6.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "exceljs": "^4.4.0"
  }
