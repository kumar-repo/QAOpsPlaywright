{
  "name": "playwright-automation-framwork",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "regression": "npx playwright test --project=chromium",
    "EcommersE2ETest": "npx playwright test EcommersE2ETestPO.spec.js --config playwright.config_custom.js --project=chromium",
    "webTests": "npx playwright test --grep @web",
    "APItests": "npx playwright test --grep @API --reporter=line,allure-playwright",
    "safaribrowser": "npx playwright test EcommersE2ETestPO.spec.js --config playwright.config_custom.js --project='webkit'",
    "chromebrowser": "npx playwright test EcommersE2ETestPO.spec.js --config playwright.config_custom.js --project='chromium'",
    "CucumberTest": "npx cucumber-js --tags '@Regression' --retry 1  --exit --format  html:cucumber-report.html"
  },
